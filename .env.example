# ================================================================
# HeritageGraph Environment Configuration
# ================================================================
# Copy this file to .env and fill in your actual values
# Do NOT commit .env to version control
# ================================================================

# ================================================================
# ENVIRONMENT MODE
# ================================================================
# Set to 'development' or 'production'
ENVIRONMENT=development
DEBUG=False

# ================================================================
# DJANGO CONFIGURATION
# ================================================================
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production
DJANGO_SETTINGS_MODULE=heritage_graph.settings.production
ALLOWED_HOSTS=localhost,127.0.0.1,backend.localhost,backend.example.com

# Django Superuser (for initial setup)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme123!

# ================================================================
# DATABASE CONFIGURATION
# ================================================================
# PostgreSQL Database for Django & Keycloak
DB_ENGINE=django.db.backends.postgresql
DB_NAME=heritage_db
DB_USER=heritage_user
DB_PASSWORD=your-db-password-change-this
DB_HOST=postgres
DB_PORT=5432

# Keycloak Database
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=your-keycloak-db-password-change-this

# ================================================================
# KEYCLOAK CONFIGURATION
# ================================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=your-keycloak-admin-password
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=your-keycloak-db-password-change-this
KC_HOSTNAME=keycloak.localhost
KC_PROXY=edge
KC_PROXY_ADDRESS_FORWARDING=true
KC_METRICS_ENABLED=true
KC_HTTP_ENABLED=true

# Keycloak Client Configuration (for frontend)
KEYCLOAK_REALM=heritage
KEYCLOAK_CLIENT_ID=heritage-ui
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret

# ================================================================
# FRONTEND CONFIGURATION (Next.js)
# ================================================================
NEXT_PUBLIC_API_URL=http://backend.localhost/api
NEXT_PUBLIC_KEYCLOAK_URL=http://keycloak.localhost
NEXT_PUBLIC_KEYCLOAK_REALM=heritage
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=heritage-ui

# ================================================================
# BACKEND CONFIGURATION
# ================================================================
# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://frontend.localhost,https://example.com

# API Configuration
API_TITLE=HeritageGraph API
API_VERSION=v1
API_DESCRIPTION=Digital Heritage Graph API

# ================================================================
# TRAEFIK CONFIGURATION
# ================================================================
# Dashboard access control
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=your-hashed-password-or-password
# Generate with: htpasswd -n admin
# Or use: openssl passwd -apr1

# SSL/TLS Configuration (for production with Let's Encrypt)
TRAEFIK_ACME_EMAIL=admin@example.com
TRAEFIK_ACME_STORAGE=/etc/traefik/acme/acme.json
ACME_ENABLED=false
# Set to true and configure Let's Encrypt email for production

# ================================================================
# LOGGING
# ================================================================
LOG_LEVEL=INFO

# ================================================================
# EMAIL CONFIGURATION (optional)
# ================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@heritage.example.com

# ================================================================
# EXTERNAL SERVICES (if applicable)
# ================================================================
# Oxigraph RDF Database (if used)
OXIGRAPH_URL=http://oxigraph:7878

# Clerk Authentication (if using Clerk instead of Keycloak)
CLERK_SECRET_KEY=your-clerk-secret-key

# ================================================================
# DOCKER & DEPLOYMENT
# ================================================================
# Docker registry for pushing images
DOCKER_REGISTRY=your-registry
DOCKER_USERNAME=your-username
DOCKER_PASSWORD=your-password

# Deployment URLs
DOMAIN=example.com
PRODUCTION_URL=https://heritage.example.com

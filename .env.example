# ================================================================
# HeritageGraph Environment Configuration
# ================================================================
# Copy this file to .env and fill in your actual values
# Do NOT commit .env to version control
# ================================================================

# ================================================================
# ENVIRONMENT MODE
# ================================================================
# Set to 'development' or 'production'
ENVIRONMENT=development
DEBUG=False

# ================================================================
# DJANGO CONFIGURATION
# ================================================================
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production
DJANGO_SETTINGS_MODULE=heritage_graph.settings.production
ALLOWED_HOSTS=localhost,127.0.0.1,backend.localhost,heritagegraph.xyz,www.heritagegraph.xyz,api.heritagegraph.xyz

# Django Superuser (for initial setup)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme123!

# ================================================================
# DATABASE CONFIGURATION
# ================================================================
# PostgreSQL Database for Django
DB_ENGINE=django.db.backends.postgresql
DB_NAME=heritage_db
DB_USER=heritage_user
DB_PASSWORD=your-db-password-change-this
DB_HOST=postgres
DB_PORT=5432

# PostgreSQL superuser (for init scripts)
POSTGRES_DB=heritage_db
POSTGRES_USER=heritage_user
POSTGRES_PASSWORD=your-db-password-change-this

# ================================================================
# GOOGLE OAUTH CONFIGURATION
# ================================================================
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ================================================================
# GITHUB OAUTH CONFIGURATION
# ================================================================
# Get these from https://github.com/settings/developers → OAuth Apps
GITHUB_ID=your-github-client-id
GITHUB_SECRET=your-github-client-secret
# Also set on the backend so Django can identify GitHub tokens
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ================================================================
# FRONTEND CONFIGURATION (Next.js)
# ================================================================
# Development: http://backend.localhost  |  Production: https://api.heritagegraph.xyz
NEXT_PUBLIC_API_URL=http://backend.localhost

# ================================================================
# BACKEND CONFIGURATION
# ================================================================
# CORS Settings
# Development: http://localhost:3000,http://frontend.localhost
# Production:  https://heritagegraph.xyz,https://www.heritagegraph.xyz
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://frontend.localhost

# API Configuration
API_TITLE=HeritageGraph API
API_VERSION=v1
API_DESCRIPTION=Digital Heritage Graph API

# ================================================================
# TRAEFIK CONFIGURATION
# ================================================================
# Dashboard access control
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=your-hashed-password-or-password
# Generate with: htpasswd -n admin
# Or use: openssl passwd -apr1

# SSL/TLS Configuration (for production with Let's Encrypt)
TRAEFIK_ACME_EMAIL=admin@heritagegraph.xyz
TRAEFIK_ACME_STORAGE=/etc/traefik/acme/acme.json
ACME_ENABLED=false
# Set to true and configure Let's Encrypt email for production

# ================================================================
# LOGGING
# ================================================================
LOG_LEVEL=INFO

# ================================================================
# EMAIL CONFIGURATION (optional)
# ================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@heritagegraph.xyz

# ================================================================
# EXTERNAL SERVICES (if applicable)
# ================================================================
# Oxigraph RDF Database (if used)
OXIGRAPH_URL=http://oxigraph:7878

# ================================================================
# DOCKER & DEPLOYMENT
# ================================================================
# Docker registry for pushing images
DOCKER_REGISTRY=your-registry
DOCKER_USERNAME=your-username
DOCKER_PASSWORD=your-password

# Deployment URLs
# Domain used by Traefik for routing (production)
DOMAIN=heritagegraph.xyz
PRODUCTION_URL=https://heritagegraph.xyz

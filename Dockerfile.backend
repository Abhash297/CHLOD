# ================================================================
# Multi-stage build for Django REST Framework backend
# ================================================================

# Stage 1: Builder
FROM python:3.13-slim as builder

# Prevent Python from writing .pyc files and buffering stdout/stderr
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /build

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY heritage_graph/requirements.txt .

# Create wheels for dependencies (faster installation in runtime image)
RUN pip install --upgrade pip setuptools wheel && \
    pip wheel --no-cache-dir --no-deps --wheel-dir /build/wheels -r requirements.txt

# ================================================================
# Stage 2: Runtime
FROM python:3.13-slim

# Prevent Python from writing .pyc files and buffering stdout/stderr
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

# Create non-root user for security
RUN useradd -m -u 1000 django

# Set working directory — /app/heritage_graph/ so manage.py is in CWD
# and 'heritage_graph' is a proper Python package under /app/
WORKDIR /app/heritage_graph

# PYTHONPATH=/app so 'import heritage_graph.wsgi' resolves to /app/heritage_graph/wsgi.py
ENV PYTHONPATH=/app

# Install runtime dependencies only
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    curl \
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# Copy wheels from builder and install
COPY --from=builder /build/wheels /wheels
COPY heritage_graph/requirements.txt /tmp/requirements.txt
RUN pip install --upgrade pip && \
    pip install --no-cache /wheels/*

# Copy application code into /app/heritage_graph/ (creates a proper Python package)
COPY ./heritage_graph /app/heritage_graph

# Create necessary directories
RUN mkdir -p /app/heritage_graph/staticfiles /app/heritage_graph/media && \
    chown -R django:django /app

# Ensure entrypoint script is executable
RUN chmod +x /app/heritage_graph/entrypoint.sh

# Switch to non-root user
USER django

# Expose port
EXPOSE 8000

# Health check endpoint
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8000/health/ || exit 1

# Entrypoint
ENTRYPOINT ["/app/heritage_graph/entrypoint.sh"]
CMD ["gunicorn", "heritage_graph.wsgi:application", "--bind", "0.0.0.0:8000", "--workers", "4", "--worker-class", "sync", "--max-requests", "1000", "--max-requests-jitter", "100", "--timeout", "60", "--access-logfile", "-", "--error-logfile", "-"]
# Frontend URLs
NEXTAUTH_URL=http://localhost:3000

# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-change-this

# ----------------------------------------------------------------
# Google OAuth (REQUIRED — primary auth provider)
# Get from https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/auth/callback/google
# ----------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ----------------------------------------------------------------
# GitHub OAuth (OPTIONAL — secondary provider, ready for later)
# Get from https://github.com/settings/developers → OAuth Apps
# Callback URL: http://localhost:3000/api/auth/callback/github
# ----------------------------------------------------------------
# GITHUB_ID=your-github-client-id
# GITHUB_SECRET=your-github-client-secret

# Backend URL for server-side API calls
# INTERNAL_BACKEND_URL=http://localhost:8000

# Public API URL for client-side calls
NEXT_PUBLIC_API_URL=http://backend.localhost
# INTERNAL_BACKEND_URL=http://localhost:8000

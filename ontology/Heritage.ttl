                                                          rdfs:range <https://w3id.org/heritagegraph/Guthi> ;
                                                          rdfs:label "supported_by_institution" ;
                                                          <http://www.w3.org/2004/02/skos/core#definition> "Institution(s) providing economic support (stipend, land endowment) or ritual support (priest salaries) for a Living Goddess during tenure. Extends Guthi role beyond structure management to person support." ;
                                                          <http://www.w3.org/2004/02/skos/core#inScheme> <file:/input/CulturalHeritageOntology> .



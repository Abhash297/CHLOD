@prefix : <file:/input/CulturalHeritageOntology.owl.ttl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <file:/input/CulturalHeritageOntology.owl.ttl#> .

<file:/input/CulturalHeritageOntology.owl.ttl> rdf:type owl:Ontology ;
                                                <http://purl.org/dc/terms/creator> "Cair Nepal" ;
                                                <http://purl.org/dc/terms/license> "CC-BY-4.0" ,
                                                                                   "https://creativecommons.org/licenses/by/4.0/" ;
                                                <http://purl.org/dc/terms/publisher> "Cair Nepal" ;
                                                <http://purl.org/pav/version> "0.1.0-alpha.2" ;
                                                rdfs:label "CulturalHeritageOntology" ;
                                                owl:imports "http://www.cidoc-crm.org/cidoc-crm/ http://www.w3.org/ns/prov#" ;
                                                owl:ontologyIRI "https://w3id.org/heritagegraph/ontology" ;
                                                owl:versionIRI "https://w3id.org/heritagegraph/ontology/0.1.0-alpha.2" ;
                                                <http://www.w3.org/2004/02/skos/core#definition> "An event-centric LinkML schema for representing cultural heritage information that fully aligns with CIDOC-CRM and PROV-O, enabling provenance tracking and ritual-spatial-temporal reasoning." .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/publisher
<http://purl.org/dc/terms/publisher> rdf:type owl:AnnotationProperty .


###  http://purl.org/pav/version
<http://purl.org/pav/version> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#imports
owl:imports rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#ontologyIRI
owl:ontologyIRI rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#versionIRI
owl:versionIRI rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#broadMatch
<http://www.w3.org/2004/02/skos/core#broadMatch> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#closeMatch
<http://www.w3.org/2004/02/skos/core#closeMatch> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
<http://www.w3.org/2004/02/skos/core#definition> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#exactMatch
<http://www.w3.org/2004/02/skos/core#exactMatch> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#inScheme
<http://www.w3.org/2004/02/skos/core#inScheme> rdf:type owl:AnnotationProperty .


###  https://w3id.org/linkml/permissible_values
<https://w3id.org/linkml/permissible_values> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.opengis.net/ont/geosparql#wktLiteral
<http://www.opengis.net/ont/geosparql#wktLiteral> rdf:type rdfs:Datatype ;
                                                  owl:equivalentClass xsd:string .


###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/heritagegraph/architectural_elements
<https://w3id.org/heritagegraph/architectural_elements> rdf:type owl:ObjectProperty ;
                                                        rdfs:label "architectural_elements" ;
                                                        <http://www.w3.org/2004/02/skos/core#definition> "Collection of ArchitecturalElement instances" ;
                                                        <http://www.w3.org/2004/02/skos/core#inScheme> <file:/input/CulturalHeritageOntology> .


###  https://w3id.org/heritagegraph/architectural_structures
<https://w3id.org/heritagegraph/architectural_structures> rdf:type owl:ObjectProperty ;
                                                          rdfs:range <https://w3id.org/heritagegraph/ArchitecturalStructure> ;
                                                          rdfs:label "architectural_structures" ;
                                                          <http://www.w3.org/2004/02/skos/core#definition> "Heritage structures affected by or present during this historical event" ;
                                                          <http://www.w3.org/2004/02/skos/core#inScheme> <file:/input/CulturalHeritageOntology> .


###  https://w3id.org/heritagegraph/assertion_author
<https://w3id.org/heritagegraph/assertion_author> rdf:type owl:ObjectProperty ;
                                                  rdfs:range <https://w3id.org/heritagegraph/Actor> ;
                                                  rdfs:label "assertion_author" ;
                                                  <http://www.w3.org/2004/02/skos/core#definition> "The agent (scholar, priest, or tradition-bearer) making or recording the syncretic claim." ;
                                                  <http://www.w3.org/2004/02/skos/core#inScheme> <file:/input/CulturalHeritageOntology> .


###  https://w3id.org/heritagegraph/asserts_about_entity
<https://w3id.org/heritagegraph/asserts_about_entity> rdf:type owl:ObjectProperty ;
                                                      rdfs:range <https://w3id.org/heritagegraph/AssertableEntity> ;
                                                      rdfs:label "asserts_about_entity" ;
                                                      <http://www.w3.org/2004/02/skos/core#inScheme> <file:/input/CulturalHeritageOntology> .


###  https://w3id.org/heritagegraph/asserts_about_event
<https://w3id.org/heritagegraph/asserts_about_event> rdf:type owl:ObjectProperty ;
                                                     rdfs:range <https://w3id.org/heritagegraph/RitualEvent> ;
                                                     rdfs:label "asserts_about_event" ;
                                                     <http://www.w3.org/2004/02/skos/core#inScheme> <file:/input/CulturalHeritageOntology> .


###  https://w3id.org/heritagegraph/assessed_condition_state
<https://w3id.org/heritagegraph/assessed_condition_state> rdf:type owl:ObjectProperty ;
                                                          rdfs:range <https://w3id.org/heritagegraph/ConditionState> ;
                                                          rdfs:label "assessed_condition_state" ;
                                                          <http://www.w3.org/2004/02/skos/core#definition> "Condition state identified by the assessment" ;
                                                          <http://www.w3.org/2004/02/skos/core#inScheme> <file:/input/CulturalHeritageOntology> .


###  https://w3id.org/heritagegraph/assessed_object
<https://w3id.org/heritagegraph/assessed_object> rdf:type owl:ObjectProperty ;
                                                 rdfs:range <https://w3id.org/heritagegraph/PhysicalHeritageThing> ;
                                                 rdfs:label "assessed_object" ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "Object assessed for condition" ;
                                                 <http://www.w3.org/2004/02/skos/core#inScheme> <file:/input/CulturalHeritageOntology> .


###  https://w3id.org/heritagegraph/assigned_equivalent
<https://w3id.org/heritagegraph/assigned_equivalent> rdf:type owl:ObjectProperty ;
                                                     rdfs:range <https://w3id.org/heritagegraph/Deity> ;
                                                     rdfs:label "assigned_equivalent" ;
                                                     <http://www.w3.org/2004/02/skos/core#definition> "The deity or sacred figure being identified as equivalent to the primary deity." ;
                                                     <http://www.w3.org/2004/02/skos/core#inScheme> <file:/input/CulturalHeritageOntology> .


###  https://w3id.org/heritagegraph/assigned_to_deity
<https://w3id.org/heritagegraph/assigned_to_deity> rdf:type owl:ObjectProperty ;
                                                   rdfs:range <https://w3id.org/heritagegraph/Deity> ;
                                                   rdfs:label "assigned_to_deity" ;
                                                   <http://www.w3.org/2004/02/skos/core#definition> "The deity instance that is the subject of the syncretic claim." ;
                                                   <http://www.w3.org/2004/02/skos/core#inScheme> <file:/input/CulturalHeritageOntology> .



###  http://vocab.getty.edu/aat/300001285
<http://vocab.getty.edu/aat/300001285> rdf:type owl:Class ;
                                       rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                       rdfs:label "Dome" ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "Dome-based style (Mughal/Neo-classical influence)" .


###  http://vocab.getty.edu/aat/300004829
<http://vocab.getty.edu/aat/300004829> rdf:type owl:Class ;
                                       rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                       rdfs:label "Pagoda" ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "Multi-tiered roof style indigenous to Nepal" .


###  http://vocab.getty.edu/aat/300007562
<http://vocab.getty.edu/aat/300007562> rdf:type owl:Class ;
                                       rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                       rdfs:label "Chaitya" ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "Buddhist votive shrine style" .


###  http://vocab.getty.edu/aat/300007576
<http://vocab.getty.edu/aat/300007576> rdf:type owl:Class ;
                                       rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                       rdfs:label "Stupa" ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "Buddhist dome-shaped reliquary" .


###  http://vocab.getty.edu/aat/300446671
<http://vocab.getty.edu/aat/300446671> rdf:type owl:Class ;
                                       rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                       rdfs:label "Shikhara" ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "North Indian spire-shaped style" .


###  http://www.cidoc-crm.org/cidoc-crm/E55_Type
<http://www.cidoc-crm.org/cidoc-crm/E55_Type> rdf:type owl:Class ;
                                              owl:equivalentClass [ rdf:type owl:Class ;
                                                                    owl:unionOf ( <http://vocab.getty.edu/aat/300001285>
                                                                                  <http://vocab.getty.edu/aat/300004829>
                                                                                  <http://vocab.getty.edu/aat/300007562>
                                                                                  <http://vocab.getty.edu/aat/300007576>
                                                                                  <http://vocab.getty.edu/aat/300446671>
                                                                                )
                                                                  ] ;
                                              rdfs:label "ArchitecturalStyleEnum" ;
                                              <http://www.w3.org/2004/02/skos/core#definition> "A vocabulary of architectural styles for South Asian heritage, mapped to CIDOC E55 Type." ;
                                              <http://www.w3.org/2004/02/skos/core#inScheme> <file:/input/CulturalHeritageOntology> ;
                                              <https://w3id.org/linkml/permissible_values> <http://vocab.getty.edu/aat/300001285> ,
                                                                                           <http://vocab.getty.edu/aat/300004829> ,
                                                                                           <http://vocab.getty.edu/aat/300007562> ,
                                                                                           <http://vocab.getty.edu/aat/300007576> ,
                                                                                           <http://vocab.getty.edu/aat/300446671> .


###  https://w3id.org/heritagegraph/Abhisheka
<https://w3id.org/heritagegraph/Abhisheka> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://w3id.org/heritagegraph/RitualTypeEnum> ;
                                           rdfs:label "Abhisheka" ;
                                           <http://www.w3.org/2004/02/skos/core#definition> "Ritual bathing/anointing of deity" ;
                                           <http://www.w3.org/2004/02/skos/core#exactMatch> <http://vocab.getty.edu/aat/300264383> .


###  https://w3id.org/heritagegraph/Actor
<https://w3id.org/heritagegraph/Actor> rdf:type owl:Class ;
                                       rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://w3id.org/heritagegraph/name> ;
                                                         owl:allValuesFrom xsd:string
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://w3id.org/heritagegraph/note> ;
                                                         owl:allValuesFrom xsd:string
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://w3id.org/heritagegraph/name> ;
                                                         owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://w3id.org/heritagegraph/note> ;
                                                         owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://w3id.org/heritagegraph/name> ;
                                                         owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://w3id.org/heritagegraph/note> ;
                                                         owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                       ] ;
                                       rdfs:label "Actor" ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "General actor (person or group) responsible for events" ;
                                       <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.cidoc-crm.org/cidoc-crm/E39_Actor> ;
                                       <http://www.w3.org/2004/02/skos/core#inScheme> <file:/input/CulturalHeritageOntology> .


###  https://w3id.org/heritagegraph/ArchitecturalElement
<https://w3id.org/heritagegraph/ArchitecturalElement> rdf:type owl:Class ;
                                                      rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <https://w3id.org/heritagegraph/is_component_of> ;
                                                                        owl:allValuesFrom <https://w3id.org/heritagegraph/ArchitecturalStructure>
                                                                      ] ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <https://w3id.org/heritagegraph/is_component_of> ;
                                                                        owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                                      ] ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <https://w3id.org/heritagegraph/is_component_of> ;
                                                                        owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                                      ] ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <https://w3id.org/heritagegraph/name> ;
                                                                        owl:allValuesFrom xsd:string
                                                                      ] ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <https://w3id.org/heritagegraph/note> ;
                                                                        owl:allValuesFrom xsd:string
                                                                      ] ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <https://w3id.org/heritagegraph/name> ;
                                                                        owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                                      ] ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <https://w3id.org/heritagegraph/note> ;
                                                                        owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                                      ] ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <https://w3id.org/heritagegraph/name> ;
                                                                        owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                                      ] ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <https://w3id.org/heritagegraph/note> ;
                                                                        owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                                      ] ;
                                                      rdfs:label "ArchitecturalElement" ;
                                                      <http://www.w3.org/2004/02/skos/core#definition> "Carved or constructed component of a architectural strucuture (e.g., Gajur, Torana, Tundal)" ;
                                                      <http://www.w3.org/2004/02/skos/core#exactMatch> <http://vocab.getty.edu/aat/300001819> ,
                                                                                                       <http://www.cidoc-crm.org/cidoc-crm/E25_Architectural_Element> ;
                                                      <http://www.w3.org/2004/02/skos/core#inScheme> <file:/input/CulturalHeritageOntology> .


###  https://w3id.org/heritagegraph/ArchitecturalStructure
<https://w3id.org/heritagegraph/ArchitecturalStructure> rdf:type owl:Class ;
                                                        rdfs:subClassOf <https://w3id.org/heritagegraph/HumanMadeObject> ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/destruction_event> ;
                                                                          owl:allValuesFrom <https://w3id.org/heritagegraph/DestructionEvent>
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/documented_in_source> ;
                                                                          owl:allValuesFrom <https://w3id.org/heritagegraph/DataSource>
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/existence_status> ;
                                                                          owl:allValuesFrom <https://w3id.org/heritagegraph/ExistenceStatusEnum>
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/has_architectural_style> ;
                                                                          owl:allValuesFrom <http://www.cidoc-crm.org/cidoc-crm/E55_Type>
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/has_component> ;
                                                                          owl:allValuesFrom <https://w3id.org/heritagegraph/ArchitecturalElement>
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/has_condition_assessment> ;
                                                                          owl:allValuesFrom <https://w3id.org/heritagegraph/ConditionAssessment>
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/has_current_location> ;
                                                                          owl:allValuesFrom <https://w3id.org/heritagegraph/Place>
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/has_provenance_assertion> ;
                                                                          owl:allValuesFrom <https://w3id.org/heritagegraph/HeritageAssertion>
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/hypothesized_location> ;
                                                                          owl:allValuesFrom <https://w3id.org/heritagegraph/Place>
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/was_produced_by_event> ;
                                                                          owl:allValuesFrom <https://w3id.org/heritagegraph/Production>
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/destruction_event> ;
                                                                          owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/documented_in_source> ;
                                                                          owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/existence_status> ;
                                                                          owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/has_architectural_style> ;
                                                                          owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/has_component> ;
                                                                          owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/has_condition_assessment> ;
                                                                          owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/has_current_location> ;
                                                                          owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/has_provenance_assertion> ;
                                                                          owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <https://w3id.org/heritagegraph/hypothesized_location> ;
                                                                          owl:minCardinality "0"^^xsd:nonNegativeInteger

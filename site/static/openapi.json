  /data/leaderboard/:
    get:
      operationId: data_leaderboard_retrieve
      description: |-
        Public leaderboard that ranks users by their contributions.

        Scoring:
          - Each accepted CulturalEntity    = 10 pts
          - Each submitted CulturalEntity    =  3 pts
          - Each review decision             =  5 pts
          - Each revision created            =  2 pts
          - Each accepted legacy Submission  = 10 pts
          - Each legacy Submission           =  3 pts

        Supports ?search= query param to filter by username.
      tags:
      - data
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          description: No response body
components:
  schemas:
    ActionEnum:
      enum:
      - create
      - update
      - delete
      type: string
      description: |-
        * `create` - Create
        * `update` - Update
        * `delete` - Delete
    Activation:
      type: object
      properties:
        uid:
          type: string
        token:
          type: string
      required:
      - token
      - uid
    Activity:
      type: object
      properties:
        activity_id:
          type: string
          format: uuid
          readOnly: true
        user:
          allOf:
          - $ref: '#/components/schemas/User'
          readOnly: true
        activity_type:
          $ref: '#/components/schemas/ActivityTypeEnum'
        comment:
          type: string
          nullable: true
          description: Optional comment from editor or contributor
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - activity_id
      - activity_type
      - created_at
      - user
    ActivityTypeEnum:
      enum:
      - submitted
      - accepted
      - rejected
      - revised
      - commented
      - escalated
      - changes_requested
      - flagged
      - conflict_resolved
      type: string
      description: |-
        * `submitted` - Submitted
        * `accepted` - Accepted
        * `rejected` - Rejected
        * `revised` - Revised
        * `commented` - Commented
        * `escalated` - Escalated to Expert
        * `changes_requested` - Changes Requested
        * `flagged` - Flagged for Review
        * `conflict_resolved` - Conflict Resolved
    ArchitecturalStructure:
      type: object
      description: Mixin to add cultural_entity_id to CIDOC serializers.
      properties:
        id:
          type: integer
          readOnly: true
        cultural_entity_id:
          type: string
          readOnly: true
        title:
          type: string
          nullable: true
          maxLength: 255
        description:
          type: string
          nullable: true
        contributor:
          type: string
          nullable: true
          maxLength: 255
        status:
          type: string
          nullable: true
          maxLength: 50
        created_at:
          type: string
          format: date-time
          readOnly: true
        name:
          type: string
          maxLength: 200
        structure_type:
          $ref: '#/components/schemas/StructureTypeEnum'
        architectural_style:
          oneOf:
          - $ref: '#/components/schemas/ArchitecturalStyleEnum'
          - $ref: '#/components/schemas/BlankEnum'
        construction_date:
          type: string
          maxLength: 100
        location_name:
          type: string
          maxLength: 200
        coordinates:
          type: string
          description: Lat, Long
          maxLength: 50
        existence_status:
          oneOf:
          - $ref: '#/components/schemas/ExistenceStatusEnum'
          - $ref: '#/components/schemas/BlankEnum'
        condition:
          oneOf:
          - $ref: '#/components/schemas/ConditionEnum'
          - $ref: '#/components/schemas/BlankEnum'
        note:
          type: string
      required:
      - created_at
      - cultural_entity_id
      - id
      - name
      - structure_type
    ArchitecturalStyleEnum:
      enum:
      - Pagoda
      - Shikhara
      - Stupa
      - Dome
      - Mughal
      - Rana_Neoclassical
      - Mixed
      - Other
      type: string
      description: |-
        * `Pagoda` - Pagoda
        * `Shikhara` - Shikhara
        * `Stupa` - Stupa
        * `Dome` - Dome
        * `Mughal` - Mughal
        * `Rana_Neoclassical` - Rana Neoclassical
        * `Mixed` - Mixed
        * `Other` - Other
    AssertionAwareDeity:
      type: object
      description: Deity serializer with inline assertion support.
      properties:
        id:
          type: integer
          readOnly: true
        assertion:
          allOf:
          - $ref: '#/components/schemas/InlineAssertion'
          writeOnly: true
        assertions:
          type: array
          items:
            $ref: '#/components/schemas/HeritageAssertion'
          readOnly: true
        title:
          type: string
          nullable: true
          maxLength: 255
        description:
          type: string
          nullable: true
        contributor:
          type: string
          nullable: true
          maxLength: 255
        status:
          type: string
          nullable: true
          maxLength: 50
        created_at:
          type: string
          format: date-time
          readOnly: true
        name:
          type: string
          maxLength: 200
        religious_tradition:
          type: string
          maxLength: 100
        alternate_names:
          type: string
          description: Comma-separated
        note:
          type: string
      required:
      - assertions
      - created_at
      - id
      - name
